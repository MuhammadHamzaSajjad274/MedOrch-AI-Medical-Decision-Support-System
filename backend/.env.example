# Medical Assistant — copy to .env and fill values
# Never commit backend/.env

# Mistral-7B medical LLM (OpenAI-compatible)
# Ollama local: ollama serve && ollama pull <your-medical-model>
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=mistral-7b-medical
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# Optional web search (Tavily)
TAVILY_API_KEY=

# Vector store
QDRANT_URL=http://localhost:6333

# Vision
USE_MOCK_MODELS=true
LOG_LEVEL=INFO
EMBED_DEVICE=auto

# Voice (Whisper STT + Piper TTS)
WHISPER_MODEL=base.en
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=
WHISPER_BEAM_SIZE=5
PIPER_MODEL_PATH=../models/piper/en_US-lessac-medium.onnx
VOICE_WARMUP_ON_STARTUP=true
TTS_MAX_CHARS=1200

# Auth — set a strong secret in production
JWT_SECRET=change-me-in-production
# DATABASE_URL=sqlite+aiosqlite:///./medical_assistant.db

# Optional: Kaggle dataset download (scripts/download_vision_weights.py)
KAGGLE_USERNAME=
KAGGLE_KEY=
